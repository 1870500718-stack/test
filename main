def darken_color(self, color): 829
"""使颜色变深""" 830
color_map={ 831
"#27ae60": "#1e8449", 832
"#3498db": "#2874a6", 833
"#e74c3c": "#c0392b", 834
"#f39c12": "#d68910" 835
} 836
return color_map.get(color, color) 837
