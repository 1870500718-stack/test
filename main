classMatplotlibCanvas(FigureCanvas): 608
"""Matplotlib画布""" 609
def __init__(self, parent=None, width=5, height=4, dpi=100): 610
self.fig=Figure(figsize=(width, height), dpi=dpi) 611
super().__init__(self.fig) 612
self.setParent(parent) 613
